# -------------------------------------------------------------------
# logging-middleware — environment variable reference
# -------------------------------------------------------------------
# Copy the relevant variable into the consuming project's .env file.
# Never commit real tokens to source control.

# Used by the Node.js / Express backend
LOG_AUTH_TOKEN=<your_bearer_token_here>

# Used by the Vite / React frontend (must be prefixed with VITE_)
VITE_LOG_AUTH_TOKEN=<your_bearer_token_here>
